{
  "name": "zmk-forge",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "description": "A ZMK keyboard configuration tool with live tuning support (fork of zmk-studio)",
  "license": "Apache-2.0",
  "author": "yuitumunii",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuitumunii/zmk-forge.git"
  },
  "homepage": "https://github.com/yuitumunii/zmk-forge",
  "bugs": {
    "url": "https://github.com/yuitumunii/zmk-forge/issues"
  },
  "keywords": [
    "zmk",
    "zmk-studio",
    "keyboard",
    "keymap",
    "electron",
    "ble"
  ],
  "scripts": {
    "generate-data": "node scripts/generate-release-data.js",
    "dev": "npm run generate-data && vite",
    "build": "npm run generate-data && tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --format=cjs --external:electron --external:@stoprocent/noble --outdir=dist-electron --out-extension:.js=.cjs",
    "electron:dev": "bash scripts/fix-electron-ble.sh && npm run build:electron && bash scripts/launch-electron-dev.sh",
    "electron:build": "npm run build && npm run build:electron && electron-builder"
  },
  "build": {
    "appId": "com.zmkforge.app",
    "productName": "ZMK Forge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/@stoprocent/noble/**/*"
    ],
    "afterPack": "scripts/electron-after-pack.cjs",
    "npmRebuild": true,
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "icon": "public/zmk-mac.png",
      "identity": null,
      "hardenedRuntime": true,
      "extendInfo": {
        "NSBluetoothAlwaysUsageDescription": "ZMK Forge connects to your keyboard over Bluetooth to read and edit its keymap.",
        "NSBluetoothPeripheralUsageDescription": "ZMK Forge connects to your keyboard over Bluetooth to read and edit its keymap."
      }
    },
    "dmg": {
      "title": "ZMK Forge"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.1",
    "@fortawesome/free-brands-svg-icons": "^6.7.1",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@stoprocent/noble": "^2.5.3",
    "@tailwindcss/container-queries": "^0.1.1",
    "@zmkfirmware/zmk-studio-ts-client": "^0.0.18",
    "emittery": "^1.0.3",
    "immer": "^10.1.1",
    "lucide-react": "^0.445.0",
    "react": "^18.2.0",
    "react-aria-components": "^1.4.0",
    "react-dom": "^18.2.0",
    "tailwindcss-react-aria-components": "^1.1.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^1.3.5",
    "@electron/fuses": "^2.1.2",
    "@electron/rebuild": "^4.0.4",
    "@storybook/addon-essentials": "^8.3.5",
    "@storybook/addon-interactions": "^8.0.10",
    "@storybook/addon-links": "^8.0.10",
    "@storybook/addon-onboarding": "^8.0.10",
    "@storybook/blocks": "^8.3.5",
    "@storybook/react": "^8.0.10",
    "@storybook/react-vite": "^8.0.10",
    "@storybook/test": "^8.0.10",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/w3c-web-serial": "^1.0.6",
    "@types/web-bluetooth": "^0.0.20",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "autoprefixer": "^10.4.19",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "eslint-plugin-storybook": "^0.8.0",
    "postcss": "^8.4.38",
    "prettier": "3.3.2",
    "run-script-os": "^1.1.6",
    "storybook": "^8.0.10",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.4.8"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "0.23.0",
    "@rollup/rollup-darwin-arm64": "^4.18.1"
  }
}
